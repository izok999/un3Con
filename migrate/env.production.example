# =============================================================================
# .env.production.example — Plantilla de variables de entorno para producción
# Copiar a .env y completar los valores marcados con <COMPLETAR>
# NUNCA commitear el .env real al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicación
# -----------------------------------------------------------------------------
APP_NAME="Consultor"
APP_ENV=production
APP_KEY=                            # Generar con: php artisan key:generate
APP_DEBUG=false                     # SIEMPRE false en producción
APP_URL=https://www.une.edu.py/consultor
APP_TIMEZONE=America/Asuncion

# Locale
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PY

# -----------------------------------------------------------------------------
# Octane (FrankenPHP)
# -----------------------------------------------------------------------------
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false                  # SSL termina en Cloudflare, no en Octane

# -----------------------------------------------------------------------------
# Base de datos LOCAL — pasa por PgBouncer
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=6432                        # PgBouncer (NO el 5432 de PostgreSQL directo)
DB_DATABASE=consultor_db
DB_USERNAME=<COMPLETAR>             # Debe coincidir con pgbouncer/userlist.txt
DB_PASSWORD=<COMPLETAR>
DB_SCHEMA=public

# Importante: pool_mode=transaction en PgBouncer es incompatible con
# prepared statements. Desactivarlos en Laravel:
DB_OPTIONS='{"options": "-c statement_timeout=30000"}'

# Deshabilitar prepared statements para compatibilidad con PgBouncer transaction mode
# Agregar en config/database.php bajo pgsql → options:
# PDO::ATTR_EMULATE_PREPARES => true

# -----------------------------------------------------------------------------
# Base de datos EXTERNA (legacy) — conexión directa, sin PgBouncer
# -----------------------------------------------------------------------------
DB_EXTERNA_CONNECTION=pgsql_externa
DB_EXTERNA_HOST=10.10.254.252
DB_EXTERNA_PORT=5432                # Directo a PostgreSQL externo
DB_EXTERNA_DATABASE=<COMPLETAR>
DB_EXTERNA_USERNAME=<COMPLETAR>
DB_EXTERNA_PASSWORD=<COMPLETAR>
DB_EXTERNA_SCHEMA=public

# -----------------------------------------------------------------------------
# Redis — caché, sesiones y colas
# -----------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null                 # Configurar si Redis tiene requirepass

# Prefijos para separar datos por entorno (útil si compartís Redis)
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2

# -----------------------------------------------------------------------------
# Caché
# -----------------------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=consultor_

# -----------------------------------------------------------------------------
# Sesiones
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=480                # 8 horas en minutos
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true          # HTTPS obligatorio
SESSION_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Colas
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_LEVEL=error                     # Solo errores en producción (debug en dev)
LOG_DAILY_DAYS=14

# -----------------------------------------------------------------------------
# Correo
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=<COMPLETAR>
MAIL_PORT=587
MAIL_USERNAME=<COMPLETAR>
MAIL_PASSWORD=<COMPLETAR>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="servicios@une.edu.py"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Broadcasting (si usás WebSockets con Reverb o Pusher)
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log           # Cambiar a reverb/pusher si aplica
# REVERB_APP_ID=<COMPLETAR>
# REVERB_APP_KEY=<COMPLETAR>
# REVERB_APP_SECRET=<COMPLETAR>
# REVERB_HOST=127.0.0.1
# REVERB_PORT=8080

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Horizon (dashboard de queues)
# -----------------------------------------------------------------------------
# El dashboard está en /horizon — protegerlo en app/Providers/HorizonServiceProvider.php
# con un gate que verifique el email del usuario autenticado

# -----------------------------------------------------------------------------
# Vite (assets)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
